{
  "name": "flashcard-backend",
  "version": "1.0.0",
  "description": "Backend for AI-powered flashcard application",
  "main": "server.js",
  "scripts": {
    "start": "node --expose-gc --max-old-space-size=2048 server.js",
    "dev": "nodemon --expose-gc --max-old-space-size=2048 server.js",
    "start:prod": "NODE_ENV=production node --expose-gc --max-old-space-size=4096 server.js"
