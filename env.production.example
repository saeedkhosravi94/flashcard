# Production Environment Variables for activerecaller.com
# Copy this to .env and fill in your actual values

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Security Secrets
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_64_characters_minimum
SESSION_SECRET=your_session_secret_here_64_characters_minimum

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://activerecaller.com/api/auth/google/callback

# Google reCAPTCHA v3
GOOGLE_RECAPTCHA_SITE_KEY=6LfccAgsAAAAADwDI1gYxAoFI7xo5OAMDdxaEvGV
GOOGLE_RECAPTCHA_SECRET_KEY=6LfccAgsAAAAAKLpN-_60IG2m2nZ203Zfz9z9fuT

# URLs
BACKEND_URL=https://activerecaller.com
FRONTEND_URL=https://activerecaller.com

